# Required for submit and verify flows
HF_API_KEY=your_api_key_here
HF_BASE_URL=https://hfapi.veraanchor.com

# Dataset flows
TEST_ROOT_DIR=/path/to/your/dataset
TEST_DATASET_KEY=<org_id>.my_program.my_dataset
TEST_PROGRAM=my_program
TEST_VERSION_LABEL=v1
TEST_DISPLAY_NAME=My Dataset
TEST_EVIDENCE_POINTER=file:///path/to/your/dataset

# Verify flow (point at outputs from a previous submit run)
TEST_RECEIPT_PATH=./vera_anchor_dataset_receipts/latest/remote-receipt.json
TEST_BUNDLE_PATH=./vera_anchor_dataset_receipts/latest/remote-bundle.json